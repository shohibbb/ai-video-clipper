{
  "name": "ai-video-clipper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:generate && next build --webpack",
    "start": "next start",
    "typegen": "next typegen",
    "typecheck": "npm run typegen && tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "worker:reap": "tsx -r dotenv/config workers/reap-worker/index.ts",
    "worker:reap-polling": "tsx -r dotenv/config workers/reap-polling-worker/index.ts",
    "worker:reap-download": "tsx -r dotenv/config workers/reap-clip-download-worker/index.ts",
    "worker:reap-publish": "tsx -r dotenv/config workers/reap-publish-worker/index.ts",
    "worker:reap-publish-status": "tsx -r dotenv/config workers/reap-publish-status-worker/index.ts",
    "worker:health": "tsx -r dotenv/config scripts/worker-health.ts",
    "redis:budget": "tsx -r dotenv/config scripts/redis-command-budget.ts",
    "debug:video": "tsx -r dotenv/config scripts/debug-video-queue.ts",
    "setup:check": "tsx -r dotenv/config scripts/check-integrations.ts",
    "production:check": "tsx -r dotenv/config scripts/check-production.ts",
    "staging:smoke": "tsx -r dotenv/config scripts/smoke-staging.ts",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.105.4",
    "bullmq": "^5.76.8",
    "dotenv": "^17.4.2",
    "enhanced-resolve": "^5.24.0",
    "ioredis": "^5.10.1",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "pg": "^8.21.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3"
  },
  "description": "MVP web application for submitting source videos, processing them into short clips via the Reap API, reviewing generated clips, and publishing directly to TikTok through Reap's built-in integrations.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TaqiyudinMiftah/ai-video-clipper.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TaqiyudinMiftah/ai-video-clipper/issues"
  },
  "homepage": "https://github.com/TaqiyudinMiftah/ai-video-clipper#readme"
}
