{
  "name": "ai-video-clipper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "typegen": "next typegen",
    "typecheck": "npm run typegen && tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "worker:reap": "tsx -r dotenv/config workers/reap-worker/index.ts",
    "worker:reap-polling": "tsx -r dotenv/config workers/reap-polling-worker/index.ts",
    "worker:reap-publish": "tsx -r dotenv/config workers/reap-publish-worker/index.ts",
    "worker:reap-publish-status": "tsx -r dotenv/config workers/reap-publish-status-worker/index.ts",
    "worker:health": "tsx -r dotenv/config scripts/worker-health.ts",
    "setup:check": "tsx -r dotenv/config scripts/check-integrations.ts",
    "production:check": "tsx -r dotenv/config scripts/check-production.ts",
    "staging:smoke": "tsx -r dotenv/config scripts/smoke-staging.ts",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.105.4",
    "bullmq": "^5.76.8",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "next": "^16.2.2",
    "next-auth": "^4.24.14",
    "prisma": "^6.19.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
