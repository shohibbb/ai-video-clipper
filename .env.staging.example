# Staging app
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://staging.your-domain.com
NEXTAUTH_URL=https://staging.your-domain.com
NEXTAUTH_SECRET=replace_with_32_plus_character_secret

# Auth
# Keep disabled for shared/public staging. Enable only for private internal staging if you understand the risk.
ALLOW_DEV_AUTH=false
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Database
# Use a dedicated staging database, not local and not production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1&pool_timeout=20
# Use a direct or session-mode URL for Prisma migrations.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?connection_limit=1&pool_timeout=20

# Redis / BullMQ
# Use a dedicated staging Redis. Use rediss:// when your provider supports TLS.
REDIS_URL=rediss://USER:PASSWORD@HOST:PORT

# Storage
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=replace_with_staging_service_role_key
SUPABASE_STORAGE_BUCKET=clips-staging
MAX_SOURCE_VIDEO_UPLOAD_MB=50

# Reap API
REAP_API_KEY=replace_with_staging_or_low_risk_reap_key
REAP_BASE_URL=https://public.reap.video/api/v1/automation
REAP_DEFAULT_GENRE=talking
REAP_DEFAULT_ORIENTATION=portrait
REAP_DEFAULT_RESOLUTION=1080
REAP_DEFAULT_REFRAME=true
REAP_DEFAULT_CAPTIONS_PRESET=system_beasty
REAP_DEFAULT_ENABLE_EMOJIS=true
REAP_DEFAULT_ENABLE_HIGHLIGHTS=true
# Leave empty for auto-detect.
REAP_DEFAULT_LANGUAGE=
REAP_POLL_INTERVAL_MS=10000
REAP_POLL_TIMEOUT_MS=900000
REAP_MAX_SOURCE_VIDEO_UPLOAD_MB=500
REAP_RATE_LIMIT_MAX_REQUESTS=10
REAP_RATE_LIMIT_WINDOW_MS=60000

# Webhook
REAP_WEBHOOK_SECRET=replace_with_32_plus_character_webhook_secret
REAP_WEBHOOK_REQUIRE_TIMESTAMP=false
REAP_WEBHOOK_TOLERANCE_SECONDS=300

# Workers
REAP_WORKER_CONCURRENCY=1
REAP_POLLING_CONCURRENCY=1
REAP_PUBLISH_CONCURRENCY=1
REAP_PUBLISH_STATUS_CONCURRENCY=1

# AI Caption
OPENAI_API_KEY=
