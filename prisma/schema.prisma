generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  url
  file
}

enum VideoStatus {
  pending
  queued
  uploading_to_reap
  processing_in_reap
  downloading_from_reap
  storing_clips
  generating_caption
  ready_to_upload
  uploading_to_tiktok
  completed
  failed
  cancelled
}

enum ClipStatus {
  created
  stored
  ready_to_upload
  uploading
  uploaded
  failed
}

enum UploadStatus {
  queued
  uploading
  publishing
  completed
  failed
  cancelled
}

enum JobType {
  reap_process
  reap_publish
  generate_caption
}

enum JobStatus {
  pending
  queued
  active
  completed
  failed
  cancelled
}

enum LogLevel {
  info
  warning
  error
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  name          String?
  videos        Video[]
  clips         Clip[]
  uploadTargets UploadTarget[]
  jobs          Job[]
  logs          Log[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Video {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  sourceType        SourceType  @map("source_type")
  sourceUrl         String?     @map("source_url")
  sourceStoragePath String?     @map("source_storage_path")
  title             String?
  durationSeconds   Int?        @map("duration_seconds")
  status            VideoStatus @default(pending)
  errorMessage      String?     @map("error_message")
  retryCount        Int         @default(0) @map("retry_count")
  reapProjectId     String?     @map("reap_project_id")
  clips             Clip[]
  jobs              Job[]
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([reapProjectId])
  @@map("videos")
}

model Clip {
  id              String         @id @default(uuid()) @db.Uuid
  videoId         String         @map("video_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  reapClipId      String?        @map("reap_clip_id")
  storagePath     String?        @map("storage_path")
  previewUrl      String?        @map("preview_url")
  durationSeconds Int?           @map("duration_seconds")
  title           String?
  caption         String?
  hashtags        String[]       @default([])
  viralityScore   Float?         @map("virality_score")
  sourceStartTime Float?         @map("source_start_time")
  sourceEndTime   Float?         @map("source_end_time")
  status          ClipStatus     @default(created)
  uploadTargets   UploadTarget[]
  jobs            Job[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  video           Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([userId])
  @@index([videoId])
  @@index([status])
  @@index([userId, status])
  @@index([videoId, status])
  @@index([reapClipId])
  @@map("clips")
}

model UploadTarget {
  id                String       @id @default(uuid()) @db.Uuid
  clipId            String       @map("clip_id") @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  platform          String
  uploadStatus      UploadStatus @default(queued) @map("upload_status")
  uploadedUrl       String?      @map("uploaded_url")
  platformResponse  Json?        @map("platform_response")
  reapIntegrationId String?      @map("reap_integration_id")
  reapPostId        String?      @map("reap_post_id")
  scheduledAt       DateTime?   @map("scheduled_at")
  errorMessage      String?      @map("error_message")
  retryCount        Int          @default(0) @map("retry_count")
  clip              Clip         @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([clipId])
  @@index([platform])
  @@index([uploadStatus])
  @@index([userId, uploadStatus])
  @@index([clipId, platform, uploadStatus])
  @@map("upload_targets")
}

model Job {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  videoId      String?   @map("video_id") @db.Uuid
  clipId       String?   @map("clip_id") @db.Uuid
  jobType      JobType   @map("job_type")
  status       JobStatus @default(queued)
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3) @map("max_attempts")
  errorMessage String?   @map("error_message")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  logs         Log[]
  clip         Clip?     @relation(fields: [clipId], references: [id], onDelete: SetNull)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video?    @relation(fields: [videoId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([videoId])
  @@index([clipId])
  @@index([jobType])
  @@index([status])
  @@index([userId, jobType, status])
  @@index([userId, createdAt])
  @@map("jobs")
}

model Log {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String?  @map("job_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  level     LogLevel
  message   String
  metadata  Json?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([jobId])
  @@index([userId])
  @@index([level])
  @@index([jobId, createdAt])
  @@index([userId, createdAt])
  @@map("logs")
}
