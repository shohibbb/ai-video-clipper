# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ai_video_clipper
# Used by Prisma migrations. For local development this can match DATABASE_URL.
DIRECT_URL=postgresql://USER:PASSWORD@localhost:5432/ai_video_clipper

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
# Upstash free-tier planning target. Used only by npm run redis:budget and production checks.
REDIS_MONTHLY_COMMAND_QUOTA=500000
# Planning inputs for npm run redis:budget. Adjust to expected monthly volume.
REDIS_PLANNED_VIDEOS_PER_MONTH=100
REDIS_PLANNED_PUBLISHES_PER_MONTH=100
# BullMQ drainDelay is seconds; stalledInterval is milliseconds.
BULLMQ_DRAIN_DELAY_SECONDS=300
BULLMQ_STALLED_INTERVAL_MS=300000

# Auth
NEXTAUTH_SECRET=replace_with_secret
NEXTAUTH_URL=http://localhost:3000
# Set true only for local/internal development. Leave false or unset in production.
ALLOW_DEV_AUTH=true
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=dev@example.com
# OAuth providers. Email/password auth works without these; configure OAuth providers as needed.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Storage
STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=clips
MAX_SOURCE_VIDEO_UPLOAD_MB=50

# Alternative Storage
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# Reap API
REAP_API_KEY=
REAP_APP_URL=https://reap.video
REAP_BASE_URL=https://public.reap.video/api/v1/automation
REAP_DEFAULT_GENRE=talking
REAP_DEFAULT_ORIENTATION=portrait
REAP_DEFAULT_RESOLUTION=1080
REAP_DEFAULT_REFRAME=true
REAP_DEFAULT_CAPTIONS_PRESET=system_beasty
REAP_DEFAULT_ENABLE_EMOJIS=true
REAP_DEFAULT_ENABLE_HIGHLIGHTS=true
# Language for captions/subtitles. Leave empty for auto-detect from video audio.
# Examples: "id" (Indonesia), "en" (English), "es" (Spanish), "ja" (Japanese)
# REAP_DEFAULT_LANGUAGE=
REAP_POLLING_INITIAL_DELAY_MS=900000
REAP_POLL_INTERVAL_MS=300000
REAP_POLL_TIMEOUT_MS=7200000
REAP_PUBLISH_STATUS_INTERVAL_MS=120000
REAP_PUBLISH_STATUS_TIMEOUT_MS=7200000
REAP_MAX_SOURCE_VIDEO_UPLOAD_MB=500
REAP_RATE_LIMIT_MAX_REQUESTS=10
REAP_RATE_LIMIT_WINDOW_MS=60000

# Webhook
# Required for production webhook verification. Prefer HMAC signature headers when available.
# If Reap cannot send custom headers, append ?reap_webhook_secret=... to the webhook URL.
REAP_WEBHOOK_SECRET=
REAP_WEBHOOK_REQUIRE_TIMESTAMP=false
REAP_WEBHOOK_TOLERANCE_SECONDS=300

# Workers
REAP_WORKER_CONCURRENCY=1
REAP_POLLING_CONCURRENCY=1
REAP_CLIP_DOWNLOAD_CONCURRENCY=1
REAP_PUBLISH_CONCURRENCY=1
REAP_PUBLISH_STATUS_CONCURRENCY=1

# AI Caption
OPENAI_API_KEY=

# Composio API (for Instagram/TikTok OAuth integrations)
COMPOSIO_API_KEY=ak_YAIwTvzQOseBui6ov5pJ
COMPOSIO_BASE_URL=https://backend.composio.dev
